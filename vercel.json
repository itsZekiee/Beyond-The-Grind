{
    "version": 2,
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/node"
        },
        {
            "src": "backend/api/index.php",
            "use": "@vercel/php"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/api/index.php"
        },
        {
            "source": "/(.*)",
            "destination": "frontend/api/index.js"
        }
    ]
}
