{
    "version": 2,
    "public": true,
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "frontend/dist/browser/**"
                ]
            }
        },
        {
            "src": "backend/api/index.php",
            "use": "@vercel/php"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/api/index.php"
        },
        {
            "source": "/(.*)",
            "destination": "frontend/dist/server/main.js"
        }
    ]
}
