{
    "version": 2,
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist/browser"
            }
        },
        {
            "src": "backend/api/index.php",
            "use": "vercel-php@0.9.0",
            "config": {
                "excludeFiles": "frontend/**"
            }
        }
    ],
    "routes": [
        {
            "src": "^/api/(.*)",
            "dest": "/backend/api/index.php"
        },
        {
            "src": "^/(?!api/)(.*)",
            "dest": "/frontend/$1"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "^/(?!api/)(.*)",
            "dest": "/frontend/index.csr.html"
        }
    ]
}
